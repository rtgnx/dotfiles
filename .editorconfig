root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = false
indent_style = space
indent_size = 2

[*.{py,go,c,dart,sh,zsh}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
tab_width=2

[lib/**.js]
indent_style = space
indent_size = 2

[{package.json,.travis.yml}]
indent_style = space
indent_size = 2
